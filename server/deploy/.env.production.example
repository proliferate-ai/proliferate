# Public API hostname served by Caddy. Point DNS here before first startup so
# Let's Encrypt can issue a certificate.
SITE_ADDRESS=api.company.com
# Optional public endpoint check after local API health passes. The AWS stack
# sets this automatically so CloudFormation only succeeds once the advertised
# HTTPS endpoint responds.
PROLIFERATE_PUBLIC_HEALTHCHECK_URL=

# Server image source for self-hosted deploys.
PROLIFERATE_SERVER_IMAGE=ghcr.io/proliferate-ai/proliferate-server
PROLIFERATE_SERVER_IMAGE_TAG=stable
PROLIFERATE_HOST_BIN_DIR=/opt/proliferate/bin
# Optional when pulling from private ECR.
AWS_REGION=

# Bundled PostgreSQL credentials and control-plane database URL.
POSTGRES_DB=proliferate
POSTGRES_USER=proliferate
# Leave blank to auto-generate and persist on first bootstrap.
POSTGRES_PASSWORD=

# Core control-plane secrets. Leave blank to auto-generate and persist them on first bootstrap.
JWT_SECRET=
CLOUD_SECRET_KEY=

# Browser/Tauri origins that may call the control plane.
CORS_ALLOW_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,http://localhost:3000,http://127.0.0.1:3000,http://tauri.localhost,tauri://localhost

# Desktop GitHub sign-in.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Cloud workspace provider.
SANDBOX_PROVIDER=e2b
E2B_API_KEY=
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# Optional observability. Leave empty to skip.
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
SENTRY_ENVIRONMENT=self-hosted
SENTRY_RELEASE=proliferate-server@self-hosted
SENTRY_TRACES_SAMPLE_RATE=1.0
CUSTOMERIO_SITE_ID=
CUSTOMERIO_API_KEY=
ANTHROPIC_API_KEY=
AI_MAGIC_SESSION_TITLE_MODEL=claude-haiku-4-5-20251001
# Required for self-hosted cloud workspace provisioning. Place a Linux
# anyharness binary on the host inside PROLIFERATE_HOST_BIN_DIR, or set
# RUNTIME_BINARY_URL to a release tarball that contains the binary.
CLOUD_RUNTIME_SOURCE_BINARY_PATH=
RUNTIME_BINARY_URL=
# Optional checksum verification for downloaded runtime archives.
RUNTIME_BINARY_SHA256=
RUNTIME_BINARY_SHA256_URL=
CLOUD_RUNTIME_SENTRY_DSN=
CLOUD_RUNTIME_SENTRY_ENVIRONMENT=
CLOUD_RUNTIME_SENTRY_RELEASE=
CLOUD_RUNTIME_SENTRY_TRACES_SAMPLE_RATE=1.0
