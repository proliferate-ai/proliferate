# App
DEBUG=false
API_BASE_URL=http://127.0.0.1:8000
PROLIFERATE_TELEMETRY_MODE=local_dev
# Local dev stays multi-org (hosted-style personal orgs). The single-org
# default derives from telemetry mode and would otherwise flip local_dev into
# single-org mode, which 503s every sign-in on a fresh database until /setup
# is claimed. Set to true only when working on self-hosting flows.
SINGLE_ORG_MODE=false
PROLIFERATE_ANONYMOUS_TELEMETRY_ENDPOINT=https://app.proliferate.com/api/v1/telemetry/anonymous
PROLIFERATE_ANONYMOUS_TELEMETRY_DISABLED=false

# Database
DATABASE_URL=postgresql+asyncpg://proliferate:localdev@127.0.0.1:5432/proliferate
# DATABASE_ECHO=false

# Background jobs (Celery + RabbitMQ + redbeat Redis)
CELERY_BROKER_URL=amqp://guest:guest@127.0.0.1:5672//
CELERY_WORKER_QUEUES=periodic.default,default,notifications
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TIME_LIMIT_SECONDS=3600
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=3300
REDBEAT_REDIS_URL=redis://127.0.0.1:6379/0
REDBEAT_KEY_PREFIX=redbeat:proliferate:

# Comma-separated origins allowed to call the API from browsers/webviews
CORS_ALLOW_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176,http://localhost:8081,http://127.0.0.1:8081,http://localhost:3000,http://127.0.0.1:3000,http://tauri.localhost,tauri://localhost

# Auth
JWT_SECRET=change-me-to-a-random-string-in-production

# GitHub OAuth credentials (leave empty to disable)
# Register your API callback URI in GitHub:
# http://127.0.0.1:8000/auth/github/callback
# and your deployed API host equivalent.
# /auth/desktop/github/callback is a legacy compatibility callback.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# GitHub App credentials for managed-cloud repository authority.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_CALLBACK_BASE_URL=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=

# Customer.io (optional)
CUSTOMERIO_SITE_ID=
CUSTOMERIO_API_KEY=
CUSTOMERIO_APP_API_KEY=
# CUSTOMERIO_FROM_EMAIL=hello@proliferate.com
# Customer.io transactional message ID for the desktop welcome email.
# Leave blank to disable the welcome email send.
CUSTOMERIO_WELCOME_TRANSACTIONAL_MESSAGE_ID=
# FRONTEND_BASE_URL=

# Server vendor telemetry (optional; hosted_product only in v1)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=proliferate-server@0.1.0
SENTRY_TRACES_SAMPLE_RATE=1.0
SUPPORT_SLACK_WEBHOOK_URL=
SUPPORT_REPORT_S3_BUCKET=
SUPPORT_REPORT_S3_PREFIX=support/reports
SUPPORT_REPORT_S3_REGION=
SUPPORT_REPORT_UPLOAD_URL_EXPIRES_SECONDS=900
SUPPORT_REPORT_DIAGNOSTICS_MAX_BYTES=26214400
SUPPORT_REPORT_ATTACHMENT_MAX_BYTES=26214400
SUPPORT_REPORT_TOTAL_ATTACHMENT_MAX_BYTES=104857600
SUPPORT_REPORT_INTERNAL_BASE_URL=
SIGNUPS_SLACK_WEBHOOK_URL=
BILLING_POSITIVE_SLACK_WEBHOOK_URL=
BILLING_NEGATIVE_SLACK_WEBHOOK_URL=

# Secondary LLM flows (optional)
ANTHROPIC_API_KEY=
AI_MAGIC_SESSION_TITLE_MODEL=claude-haiku-4-5-20251001

# Cloud workspaces
CLOUD_SECRET_KEY=change-me-to-a-random-string-in-production
CLOUD_FREE_SANDBOX_HOURS=2000.0
CLOUD_CONCURRENT_SANDBOX_LIMIT=200
CLOUD_BILLING_MODE=off

# Agent LLM gateway (optional; requires a private LiteLLM proxy)
AGENT_GATEWAY_ENABLED=false
AGENT_GATEWAY_LITELLM_BASE_URL=http://127.0.0.1:4000
AGENT_GATEWAY_LITELLM_MASTER_KEY=
AGENT_GATEWAY_PUBLIC_BASE_URL=
AGENT_GATEWAY_DEFAULT_MANAGED_BUDGET_USD=0
AGENT_GATEWAY_MAX_REQUEST_BYTES=4194304
AGENT_GATEWAY_REQUEST_TIMEOUT_SECONDS=120.0
AGENT_GATEWAY_OPENCODE_ENABLED=false
AGENT_GATEWAY_RECONCILER_ENABLED=false
AGENT_GATEWAY_RECONCILER_INTERVAL_SECONDS=300.0
AGENT_GATEWAY_RECONCILER_BATCH_SIZE=50

# Stripe billing (test/local or hosted product wiring)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CLOUD_MONTHLY_PRICE_ID=
STRIPE_SANDBOX_METER_ID=
STRIPE_SANDBOX_METER_EVENT_NAME=proliferate_sandbox_seconds
STRIPE_SANDBOX_OVERAGE_PRICE_ID=
STRIPE_REFILL_10H_PRICE_ID=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:1420/settings/cloud?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:1420/settings/cloud?checkout=cancel
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:1420/settings/cloud

# Sandbox provider
E2B_API_KEY=
E2B_TEMPLATE_NAME=
E2B_WEBHOOK_SIGNATURE_SECRET=

# Remote AnyHarness vendor Sentry injection into cloud sandboxes (hosted_product only in v1)
CLOUD_RUNTIME_SOURCE_BINARY_PATH=
CLOUD_WORKER_SOURCE_BINARY_PATH=
CLOUD_SUPERVISOR_SOURCE_BINARY_PATH=
CLOUD_RUNTIME_SENTRY_DSN=
CLOUD_RUNTIME_SENTRY_ENVIRONMENT=development
CLOUD_RUNTIME_SENTRY_RELEASE=anyharness@0.1.0
CLOUD_RUNTIME_SENTRY_TRACES_SAMPLE_RATE=1.0
