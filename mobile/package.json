{
  "name": "@proliferate/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "build:shared": "pnpm --filter @proliferate/design build && pnpm --filter @proliferate/product-model build",
    "start": "pnpm build:shared && expo start",
    "ios": "pnpm build:shared && expo start --ios",
    "android": "pnpm build:shared && expo start --android",
    "web": "pnpm build:shared && expo start --web",
    "typecheck": "pnpm build:shared && tsc --noEmit",
    "build:ios": "pnpm build:shared && pnpm dlx eas-cli@18.13.0 build --platform ios --profile production",
    "build:ios:preview": "pnpm build:shared && pnpm dlx eas-cli@18.13.0 build --platform ios --profile preview",
    "eas-build-post-install": "pnpm build:shared",
    "submit:ios": "pnpm dlx eas-cli@18.13.0 submit --platform ios --profile production"
  },
  "dependencies": {
    "@proliferate/cloud-sdk": "workspace:*",
    "@proliferate/design": "workspace:*",
    "@proliferate/product-model": "workspace:*",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.7",
    "expo-linking": "~8.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
