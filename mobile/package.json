{
  "name": "@proliferate/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:ios": "pnpm dlx eas-cli@18.13.0 build --platform ios --profile production",
    "build:ios:preview": "pnpm dlx eas-cli@18.13.0 build --platform ios --profile preview",
    "submit:ios": "pnpm dlx eas-cli@18.13.0 submit --platform ios --profile production"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.7",
    "expo-linking": "~8.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
