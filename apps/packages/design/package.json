{
  "name": "@proliferate/design",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "import": "./dist/react-native.js"
    },
    "./theme.css": "./dist/theme.css",
    "./dom.css": "./dist/dom.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/generate-theme.mjs && node scripts/copy-dom-css.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "typescript": "^5.7"
  }
}
