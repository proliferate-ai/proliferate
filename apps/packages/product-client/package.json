{
  "name": "@proliferate/product-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "imports": {
    "#product/*": {
      "types": "./src/*",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    "./host/product-host": {
      "types": "./dist/host/product-host.d.ts",
      "import": "./dist/host/product-host.js"
    },
    "./host/desktop-bridge": {
      "types": "./dist/host/desktop-bridge.d.ts",
      "import": "./dist/host/desktop-bridge.js"
    },
    "./host/ProductHostProvider": {
      "types": "./dist/host/ProductHostProvider.d.ts",
      "import": "./dist/host/ProductHostProvider.js"
    },
    "./infra/measurement": {
      "types": "./dist/lib/infra/measurement/measurement-port.d.ts",
      "import": "./dist/lib/infra/measurement/measurement-port.js"
    },
    "./ProductClient": {
      "types": "./dist/ProductClient.d.ts",
      "import": "./dist/ProductClient.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @proliferate/cloud-sdk build && pnpm --filter @anyharness/sdk build && pnpm --filter @anyharness/sdk-react build && pnpm --filter @proliferate/product-domain build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @proliferate/cloud-sdk build && pnpm --filter @anyharness/sdk build && pnpm --filter @anyharness/sdk-react build && pnpm --filter @proliferate/product-domain build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anyharness/sdk": "workspace:*",
    "@anyharness/sdk-react": "workspace:*",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@lezer/common": "^1.2.3",
    "@lezer/highlight": "^1.2.3",
    "@monaco-editor/react": "^4",
    "@proliferate/cloud-sdk": "workspace:*",
    "@proliferate/cloud-sdk-react": "workspace:*",
    "@proliferate/design": "workspace:*",
    "@proliferate/product-domain": "workspace:*",
    "@proliferate/product-surfaces": "workspace:*",
    "@proliferate/product-ui": "workspace:*",
    "@proliferate/ui": "workspace:*",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-virtual": "3.14.3",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "cmdk": "^1.1.1",
    "geist": "^1.7.2",
    "lucide-react": "0.577.0",
    "react-markdown": "^9",
    "react-router-dom": "^7",
    "remark-gfm": "^4",
    "shiki": "^4.2.0",
    "zustand": "^5"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "~19.2.17",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^29.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "^5.7",
    "vite": "^6",
    "vitest": "^3.2.6"
  }
}
