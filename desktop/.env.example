# Local desktop-only development (`make dev-local`) does not require any of these vars.
# Self-hosted desktop users should prefer ~/.proliferate/config.json for apiBaseUrl
# overrides rather than rebuilding the app with VITE_PROLIFERATE_API_BASE_URL.
VITE_PROLIFERATE_API_BASE_URL=http://127.0.0.1:8000
VITE_PROLIFERATE_ENVIRONMENT=development
VITE_PROLIFERATE_RELEASE=proliferate-desktop@dev
VITE_PROLIFERATE_TELEMETRY_DISABLED=false

# Dev-only auth overrides
# VITE_DEV_DISABLE_AUTH=true
# VITE_REQUIRE_AUTH=true
# VITE_PROLIFERATE_DEBUG_LATENCY=true

# Desktop renderer telemetry
VITE_PROLIFERATE_SENTRY_DSN=
VITE_PROLIFERATE_SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_PROLIFERATE_SENTRY_ENABLE_LOGS=true
VITE_PROLIFERATE_POSTHOG_KEY=
VITE_PROLIFERATE_POSTHOG_HOST=https://us.i.posthog.com
VITE_PROLIFERATE_POSTHOG_SESSION_RECORDING_ENABLED=false

# Native Tauri telemetry is compiled into release builds by desktop/src-tauri/build.rs.
# Export these in your shell before running `pnpm tauri build` if you want native Sentry.
PROLIFERATE_DESKTOP_SENTRY_DSN=
PROLIFERATE_DESKTOP_SENTRY_ENVIRONMENT=development
PROLIFERATE_DESKTOP_SENTRY_RELEASE=proliferate-desktop-native@dev
PROLIFERATE_DESKTOP_SENTRY_TRACES_SAMPLE_RATE=1.0

# Bundled AnyHarness sidecar telemetry.
ANYHARNESS_SENTRY_DSN=
ANYHARNESS_SENTRY_ENVIRONMENT=development
ANYHARNESS_SENTRY_RELEASE=anyharness-sidecar@dev
ANYHARNESS_SENTRY_TRACES_SAMPLE_RATE=1.0

# Optional build-time Sentry sourcemap upload for production builds.
# These are consumed by desktop/vite.config.ts and should generally come from CI.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
