{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "types": ["node", "vitest/globals"],
    "paths": {
      "@anyharness/sdk": ["../sdk/src/index.ts"]
    }
  },
  "include": ["src"]
}
