{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.proliferate.com/schemas/catalogs/agents/v1/registry.schema.json",
  "title": "Proliferate Agent Runtime Registry",
  "type": "object",
  "required": [
    "schemaVersion",
    "registryVersion",
    "generatedAt",
    "agents"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "registryVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/agent"
      }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": [
        "kind",
        "displayName",
        "agentProcess",
        "launch",
        "auth"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "claude",
            "codex",
            "gemini",
            "cursor",
            "opencode"
          ]
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "native": {
          "anyOf": [
            {
              "$ref": "#/$defs/nativeArtifact"
            },
            {
              "type": "null"
            }
          ]
        },
        "agentProcess": {
          "$ref": "#/$defs/agentProcessArtifact"
        },
        "launch": {
          "$ref": "#/$defs/launch"
        },
        "auth": {
          "$ref": "#/$defs/auth"
        },
        "docsUrl": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "nativeArtifact": {
      "type": "object",
      "required": [
        "install"
      ],
      "additionalProperties": false,
      "properties": {
        "install": {
          "$ref": "#/$defs/nativeInstall"
        }
      }
    },
    "agentProcessArtifact": {
      "type": "object",
      "required": [
        "install"
      ],
      "additionalProperties": false,
      "properties": {
        "install": {
          "$ref": "#/$defs/agentProcessInstall"
        }
      }
    },
    "nativeInstall": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "binaryUrlTemplate",
            "platformMap"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "direct_binary"
            },
            "latestVersionUrl": {
              "type": [
                "string",
                "null"
              ]
            },
            "binaryUrlTemplate": {
              "type": "string",
              "minLength": 1
            },
            "platformMap": {
              "$ref": "#/$defs/nonEmptyStringMap"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "latestUrlTemplate",
            "versionedUrlTemplate",
            "expectedBinaryTemplate",
            "platformMap"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "tarball_release"
            },
            "latestUrlTemplate": {
              "type": "string",
              "minLength": 1
            },
            "versionedUrlTemplate": {
              "type": "string",
              "minLength": 1
            },
            "expectedBinaryTemplate": {
              "type": "string",
              "minLength": 1
            },
            "platformMap": {
              "$ref": "#/$defs/nonEmptyStringMap"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "candidateBinaries"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "path_only"
            },
            "candidateBinaries": {
              "$ref": "#/$defs/nonEmptyStringArray"
            },
            "docsUrl": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "docsUrl"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "manual"
            },
            "docsUrl": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "agentProcessInstall": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "registryId",
            "fallback"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "registry_backed"
            },
            "registryId": {
              "type": "string",
              "minLength": 1
            },
            "fallback": {
              "$ref": "#/$defs/agentProcessFallback"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "package",
            "executableRelpath"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "managed_npm_package"
            },
            "package": {
              "type": "string",
              "minLength": 1
            },
            "packageSubdir": {
              "type": [
                "string",
                "null"
              ]
            },
            "sourceBuildBinaryName": {
              "type": [
                "string",
                "null"
              ]
            },
            "executableRelpath": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "candidateBinaries",
            "defaultArgs"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "path_only"
            },
            "candidateBinaries": {
              "$ref": "#/$defs/nonEmptyStringArray"
            },
            "defaultArgs": {
              "$ref": "#/$defs/stringArray"
            },
            "docsUrl": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "docsUrl"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "manual"
            },
            "docsUrl": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "agentProcessFallback": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "package",
            "executableRelpath"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "npm_package"
            },
            "package": {
              "type": "string",
              "minLength": 1
            },
            "packageSubdir": {
              "type": [
                "string",
                "null"
              ]
            },
            "sourceBuildBinaryName": {
              "type": [
                "string",
                "null"
              ]
            },
            "executableRelpath": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "args"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "native_subcommand"
            },
            "args": {
              "$ref": "#/$defs/stringArray"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "candidateBinaries",
            "args"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "binary_hint"
            },
            "candidateBinaries": {
              "$ref": "#/$defs/nonEmptyStringArray"
            },
            "args": {
              "$ref": "#/$defs/stringArray"
            }
          }
        }
      ]
    },
    "launch": {
      "type": "object",
      "required": [
        "executableName",
        "defaultArgs"
      ],
      "additionalProperties": false,
      "properties": {
        "executableName": {
          "type": "string",
          "minLength": 1
        },
        "defaultArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "auth": {
      "type": "object",
      "required": [
        "readinessPolicy",
        "slots"
      ],
      "additionalProperties": false,
      "properties": {
        "readinessPolicy": {
          "enum": [
            "any_required_slot",
            "all_required_slots",
            "provider_managed",
            "none"
          ]
        },
        "slots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/authSlot"
          }
        }
      }
    },
    "authSlot": {
      "type": "object",
      "required": [
        "id",
        "label",
        "credentialProviderIds",
        "requiredForReadiness",
        "envVars",
        "discovery",
        "materialization"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "credentialProviderIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredForReadiness": {
          "type": "boolean"
        },
        "envVars": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "discovery": {
          "enum": [
            "none",
            "claude",
            "codex",
            "gemini",
            "opencode",
            "cursor"
          ]
        },
        "login": {
          "anyOf": [
            {
              "$ref": "#/$defs/login"
            },
            {
              "type": "null"
            }
          ]
        },
        "materialization": {
          "$ref": "#/$defs/materialization"
        }
      }
    },
    "login": {
      "type": "object",
      "required": [
        "label",
        "command",
        "reusesUserState"
      ],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "object",
          "required": [
            "program",
            "args"
          ],
          "additionalProperties": false,
          "properties": {
            "program": {
              "type": "string",
              "minLength": 1
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "reusesUserState": {
          "type": "boolean"
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "materialization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gatewayEnv": {
          "$ref": "#/$defs/gatewayEnvMaterialization"
        },
        "syncedFiles": {
          "$ref": "#/$defs/syncedFilesMaterialization"
        }
      }
    },
    "gatewayEnvMaterialization": {
      "type": "object",
      "required": [
        "protocolFacade",
        "protectedEnvKeys",
        "supportEnvKeys"
      ],
      "additionalProperties": false,
      "properties": {
        "protocolFacade": {
          "enum": [
            "anthropic",
            "openai",
            "genai"
          ]
        },
        "protectedEnvKeys": {
          "$ref": "#/$defs/stringArray"
        },
        "supportEnvKeys": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "syncedFilesMaterialization": {
      "type": "object",
      "required": [
        "protectedEnvKeys",
        "allowedFilePaths",
        "cleanupFilePaths"
      ],
      "additionalProperties": false,
      "properties": {
        "protectedEnvKeys": {
          "$ref": "#/$defs/stringArray"
        },
        "allowedFilePaths": {
          "$ref": "#/$defs/stringArray"
        },
        "cleanupFilePaths": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nonEmptyStringMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
