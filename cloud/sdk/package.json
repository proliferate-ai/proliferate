{
  "name": "@proliferate/cloud-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Proliferate Cloud control plane",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client/*": {
      "types": "./dist/client/*.d.ts",
      "import": "./dist/client/*.js"
    },
    "./streams/*": {
      "types": "./dist/streams/*.d.ts",
      "import": "./dist/streams/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js"
    },
    "./generated/openapi": {
      "types": "./dist/generated/openapi.d.ts",
      "import": "./dist/generated/openapi.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/proliferate-ai/proliferate",
    "directory": "cloud/sdk"
  },
  "dependencies": {
    "openapi-fetch": "^0.14.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
