{
  "name": "@proliferate/cloud-sdk-react",
  "version": "0.1.0",
  "description": "React helpers for the Proliferate Cloud SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./context/*": {
      "types": "./dist/context/*.d.ts",
      "import": "./dist/context/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/proliferate-ai/proliferate",
    "directory": "cloud/sdk-react"
  },
  "dependencies": {
    "@proliferate/cloud-sdk": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@types/react": "^19",
    "react": "^19",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

